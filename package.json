{
    "name": "assertive",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check-types": "turbo run check-types"
    },
    "dependencies": {
        "next": "^16.1.6",
        "postcss": "^8.5.8",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.4.4",
        "zustand": "^4.5.2"
    },
    "devDependencies": {
        "prettier": "^3.7.4",
        "husky": "^9.0.11",
        "turbo": "^2.8.9",
        "typescript": "5.9.2"
    },
    "packageManager": "pnpm@9.5.0",
    "engines": {
        "node": ">=18"
    },
    "husky": {
        "hooks": {
            "pre-commit": "yarn run prettier-format && yarn run lint"
        }
    }
}
